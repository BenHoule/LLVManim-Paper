\definecolor{listingrule}{gray}{0.80}
\definecolor{listingcomment}{rgb}{0.00,0.40,0.00}
\definecolor{listingstring}{rgb}{0.55,0.10,0.10}
\definecolor{listingkeyword}{rgb}{0.00,0.20,0.60}
\lstset{
    basicstyle=\ttfamily\footnotesize,
    breaklines=true,
    breakatwhitespace=true,
    columns=fullflexible,
    keepspaces=true,
    frame=single,
    framerule=0.5pt,
    rulecolor=\color{listingrule},
    backgroundcolor=\color{listingbg},
    framesep=5pt,
    xleftmargin=0.4em,
    framexleftmargin=0.4em,
    showstringspaces=false,
    upquote=true,
    commentstyle=\color{listingcomment},
    stringstyle=\color{listingstring},
    keywordstyle=\color{listingkeyword}\bfseries,
    captionpos=b,
    postbreak=\mbox{\textcolor{red}{$\hookrightarrow$}\space}
}

\newcommand{\TODO}[1]{\textbf{TODO (#1): }}
\newcounter{feedbackcount}
\newcommand{\feedbackset}[1]{\setcounter{feedbackcount}{#1}}
\newcommand{\feedback}[2]{%
    {\small
    \refstepcounter{feedbackcount}%
    \begin{quotation}
      [\arabic{feedbackcount}]---\textit{#1}
    \end{quotation}%
    }%
    \ifstrempty{#2}{}{%
        \noindent $Response_{[\arabic{feedbackcount}]}$---#2\par
        \vspace{1em}
    }%
}
\newcommand{\feedbackdivider}{\noindent\hrulefill\par}

% LLVM IR syntax highlighting
\lstset{
  alsoletter={.!},
  otherkeywords={!},
}
\lstdefinelanguage{llvmir}{
  sensitive=true,
  string=[b]{"},
  morecomment=[l]{;},
  % top-level / structural
  morekeywords=[1]{
    target, attributes, module, source_filename,
    target datalayout, target triple,
    global, constant, external, internal, private, weak, linkonce,
    appending, common, dso_local, dso_preemptable
  },
  % instructions
  morekeywords=[2]{
    define, declare, add, fadd, sub, fsub, mul, fmul, udiv, sdiv, fdiv,
    urem, srem, frem, shl, lshr, ashr, and, or, xor,
    alloca, load, store, getelementptr, fence, cmpxchg, atomicrmw,
    trunc, zext, sext, fptrunc, fpext, uitofp, sitofp, fptoui, fptosi,
    inttoptr, ptrtoint, bitcast, addrspacecast,
    icmp, fcmp, phi, select, call, va_arg, landingpad,
    ret, br, switch, indirectbr, invoke, callbr, resume, unreachable,
    extractelement, insertelement, shufflevector,
    extractvalue, insertvalue, fneg
  },
  % types
  morekeywords=[3]{
    void, i1, i8, i16, i32, i64, i128, half, bfloat,
    float, double, fp128, x86\_fp80, ptr, label, metadata, token
  },
  % attributes / qualifiers
  morekeywords=[4]{
    nounwind, noundef, noinline, optnone, uwtable, noreturn,
    nocallback, nofree, nosync, speculatable, willreturn, memory,
    noalias, readonly, writeonly, readnone, nonnull, dereferenceable,
    align, inbounds, nsw, nuw, exact, volatile, atomic, inrange,
    singlethread, acquire, release, acq_rel, seq_cst, unordered, monotonic,
    frame-pointer, allocsize, min-legal-vector-width, no-trapping-math,
    stack-protector-buffer-size, target-cpu, target-features, tune-cpu
  },
  morekeywords=[5]{
  !dbg, DIExpression, DILocation, DILocalVariable, DIBasicType,
  DISubprogram, DISubroutineType, DIFile, DICompileUnit,
  DILexicalBlock, DILexicalBlockFile, DIDerivedType,
  DICompositeType, DIGlobalVariable, DIGlobalVariableExpression,
  },
}
\colorlet{llvmcomment}{Green}
\colorlet{llvmkwA}{Periwinkle}
\colorlet{llvmkwB}{Blue}
\colorlet{llvmkwC}{BrickRed}
\colorlet{llvmkwD}{CadetBlue}
\lstdefinestyle{llvmirstyle}{
  language=llvmir,
  commentstyle=\color{llvmcomment}\itshape,
  keywordstyle=[1]\color{llvmkwA},
  keywordstyle=[2]\color{llvmkwB}\bfseries,
  keywordstyle=[3]\color{llvmkwB},
  keywordstyle=[4]\color{llvmkwD},
  keywordstyle=[5]\color{llvmkwC}\itshape,
  literate={!}{{\textcolor{llvmkwC}{!}}}1,
  % literate={\#}{{\textcolor{llvmkwC}{\#}}}1,
}

