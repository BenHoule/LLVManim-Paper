digraph pipeline {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=9, color="#546e7a"];
    bgcolor="white";
    nodesep=0.6;
    ranksep=1.0;

    /* ── Input ───────────────────────────────── */
    subgraph cluster_input {
        label=""; style=invis;
        ll_file [label=".ll\n(LLVM IR)", shape=note, fillcolor="#fff9c4", color="#f9a825"];
        dot_cfg [label=".dot\n(opt -dot-cfg)", shape=note, fillcolor="#fff9c4", color="#f9a825"];
        trace   [label=".json\n(exec trace)", shape=note, fillcolor="#fff9c4", color="#f9a825"];
    }

    /* ── CLI ─────────────────────────────────── */
    cli [label="llvmanim CLI\n(argparse)", fillcolor="#c5cae9", color="#3949ab",
         shape=box, width=1.6];

    /* ── Ingest ──────────────────────────────── */
    subgraph cluster_ingest {
        label="INGEST"; labelloc=b;
        style="filled,rounded"; fillcolor="#e8f5e9"; color="#43a047";
        fontsize=12; fontcolor="#1b5e20";

        parse [label="parse_module_to_events\n(llvmlite)", fillcolor="#c8e6c9", color="#2e7d32"];
        load_edges [label="load_cfg_edges", fillcolor="#c8e6c9", color="#2e7d32"];
        load_trace [label="load_trace", fillcolor="#c8e6c9", color="#2e7d32"];
        load_dot   [label="compute_dot_layout", fillcolor="#c8e6c9", color="#2e7d32"];
        load_meta  [label="load_analysis_metadata", fillcolor="#c8e6c9", color="#2e7d32"];
    }

    /* ── Transform ───────────────────────────── */
    subgraph cluster_transform {
        label="TRANSFORM"; labelloc=b;
        style="filled,rounded"; fillcolor="#fff3e0"; color="#fb8c00";
        fontsize=12; fontcolor="#e65100";

        scene_build [label="build_scene_graph\n(blocks ➜ SceneGraph)", fillcolor="#ffe0b2", color="#ef6c00"];
        cmd_build   [label="build_animation_commands\n(stream ➜ AnimationCommand[])", fillcolor="#ffe0b2", color="#ef6c00"];
    }

    /* ── Present ─────────────────────────────── */
    subgraph cluster_present {
        label="PRESENT"; labelloc=b;
        style="filled,rounded"; fillcolor="#e3f2fd"; color="#1e88e5";
        fontsize=12; fontcolor="#0d47a1";

        export_dot  [label="export_cfg_dot\nexport_cfg_png", fillcolor="#bbdefb", color="#1565c0"];
        export_json [label="export_scene_graph_json", fillcolor="#bbdefb", color="#1565c0"];
        stack_scene [label="RichStackScene\n(Manim CE)", fillcolor="#bbdefb", color="#1565c0"];
        cfg_scene   [label="CFGAnimationScene\n(Manim CE)", fillcolor="#bbdefb", color="#1565c0"];
    }

    /* ── Output ──────────────────────────────── */
    subgraph cluster_output {
        label=""; style=invis;
        out_dot  [label=".dot / .png\nCFG diagram", shape=note, fillcolor="#ffcdd2", color="#c62828"];
        out_json [label=".json\nscene graph", shape=note, fillcolor="#ffcdd2", color="#c62828"];
        out_mp4a [label=".mp4 / .gif\nstack animation", shape=note, fillcolor="#ffcdd2", color="#c62828"];
        out_mp4b [label=".mp4 / .gif\nCFG traversal", shape=note, fillcolor="#ffcdd2", color="#c62828"];
    }

    /* ── Flow ────────────────────────────────── */
    ll_file -> cli;
    dot_cfg -> cli [style=dashed];
    trace   -> cli [style=dashed];

    cli -> parse      [label="IR text"];
    cli -> load_edges [style=dashed];
    cli -> load_trace [style=dashed];
    cli -> load_dot   [style=dashed];
    cli -> load_meta  [style=dashed];

    parse      -> scene_build [label="ProgramEventStream"];
    parse      -> cmd_build   [label="ProgramEventStream"];
    load_edges -> scene_build [label="CFGEdge[]", style=dashed];
    load_trace -> scene_build [label="TraceOverlay", style=dashed];
    load_meta  -> scene_build [label="BlockMetadata", style=dashed];

    scene_build -> export_dot  [label="SceneGraph"];
    scene_build -> export_json [label="SceneGraph"];
    scene_build -> cfg_scene   [label="SceneGraph"];
    load_dot    -> cfg_scene   [label="DotLayout", style=dashed];

    cmd_build   -> stack_scene [label="AnimationCommand[]"];

    export_dot  -> out_dot;
    export_json -> out_json;
    stack_scene -> out_mp4a;
    cfg_scene   -> out_mp4b;
}
