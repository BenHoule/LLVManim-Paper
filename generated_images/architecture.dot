digraph architecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=9];
    compound=true;
    newrank=true;
    bgcolor="white";

    /* ── CLI Entry ────────────────────────────── */
    subgraph cluster_cli {
        label="CLI  (llvmanim.cli)";
        style="filled,rounded"; fillcolor="#e8eaf6"; color="#5c6bc0";
        fontsize=12; fontcolor="#283593";
        cli_main [label="main.py\n(argparse entry)", fillcolor="#c5cae9", color="#3949ab"];
    }

    /* ── Input Files ─────────────────────────── */
    subgraph cluster_input {
        label="Input Files";
        style="filled,rounded"; fillcolor="#fff8e1"; color="#ffa000";
        fontsize=12; fontcolor="#e65100";
        ir_file    [label=".ll file\n(LLVM IR)", shape=note, fillcolor="#fff9c4", color="#f9a825"];
        dot_file   [label=".dot file\n(CFG layout)", shape=note, fillcolor="#fff9c4", color="#f9a825"];
        trace_file [label=".json file\n(execution trace)", shape=note, fillcolor="#fff9c4", color="#f9a825"];
    }

    /* ── Ingest Layer ────────────────────────── */
    subgraph cluster_ingest {
        label="Ingest Layer  (llvmanim.ingest)";
        style="filled,rounded"; fillcolor="#e8f5e9"; color="#43a047";
        fontsize=12; fontcolor="#1b5e20";
        llvm_events   [label="llvm_events.py\n(IR → ProgramEventStream)", fillcolor="#c8e6c9", color="#2e7d32"];
        cfg_edge_io   [label="cfg_edge_io.py\n(CFG edge JSON I/O)", fillcolor="#c8e6c9", color="#2e7d32"];
        dot_layout    [label="dot_layout.py\n(DOT → DotLayout)", fillcolor="#c8e6c9", color="#2e7d32"];
        trace_io      [label="trace_io.py\n(trace JSON → TraceOverlay)", fillcolor="#c8e6c9", color="#2e7d32"];
        display_lines [label="display_lines.py\n(IR display formatting)", fillcolor="#c8e6c9", color="#2e7d32"];
        analysis_io   [label="analysis_metadata_io.py\n(dominators / loops)", fillcolor="#c8e6c9", color="#2e7d32"];
    }

    /* ── Transform Layer ─────────────────────── */
    subgraph cluster_transform {
        label="Transform Layer  (llvmanim.transform)";
        style="filled,rounded"; fillcolor="#fff3e0"; color="#fb8c00";
        fontsize=12; fontcolor="#e65100";
        models   [label="models.py\n(IREvent, CFGBlock,\nSceneGraph, …)", fillcolor="#ffe0b2", color="#ef6c00"];
        commands [label="commands.py\n(stream → AnimationCommand)", fillcolor="#ffe0b2", color="#ef6c00"];
        scene    [label="scene.py\n(build_scene_graph)", fillcolor="#ffe0b2", color="#ef6c00"];
        trace    [label="trace.py\n(trace overlay merge)", fillcolor="#ffe0b2", color="#ef6c00"];
    }

    /* ── Present Layer ───────────────────────── */
    subgraph cluster_present {
        label="Present Layer  (llvmanim.present)";
        style="filled,rounded"; fillcolor="#e3f2fd"; color="#1e88e5";
        fontsize=12; fontcolor="#0d47a1";

        subgraph cluster_export {
            label="Static Export";
            style="filled,rounded"; fillcolor="#bbdefb"; color="#42a5f5";
            fontsize=10; fontcolor="#1565c0";
            graphviz_export [label="graphviz_export.py\n(DOT / PNG)", fillcolor="#e3f2fd", color="#1565c0"];
            json_export     [label="json_export.py\n(scene JSON)", fillcolor="#e3f2fd", color="#1565c0"];
        }

        subgraph cluster_animation {
            label="Animation (Manim CE)";
            style="filled,rounded"; fillcolor="#bbdefb"; color="#42a5f5";
            fontsize=10; fontcolor="#1565c0";
            scene_builder  [label="scene_builder.py\n(LLVManimScene)", fillcolor="#e3f2fd", color="#1565c0"];
            render_model   [label="render_stack_model.py\n(RenderStep)", fillcolor="#e3f2fd", color="#1565c0"];
            manim_stack    [label="manim_stack.py\n(StackSlot mobjects)", fillcolor="#e3f2fd", color="#1565c0"];
            rich_stack     [label="rich_stack_scene.py\n(Badge / Spotlight)", fillcolor="#e3f2fd", color="#1565c0"];
            ssa_fmt        [label="ssa_formatting.py\n(SSA rich labels)", fillcolor="#e3f2fd", color="#1565c0"];
            cfg_anim       [label="cfg_animation_scene.py\n(CFG traversal)", fillcolor="#e3f2fd", color="#1565c0"];
        }
    }

    /* ── Output ───────────────────────────────── */
    subgraph cluster_output {
        label="Output Artifacts";
        style="filled,rounded"; fillcolor="#fce4ec"; color="#e53935";
        fontsize=12; fontcolor="#b71c1c";
        out_mp4  [label="MP4 / GIF\nAnimation", shape=note, fillcolor="#ffcdd2", color="#c62828"];
        out_png  [label="PNG / DOT\nCFG Diagram", shape=note, fillcolor="#ffcdd2", color="#c62828"];
        out_json [label="JSON\nScene Graph", shape=note, fillcolor="#ffcdd2", color="#c62828"];
    }

    /* ── Edges: CLI → Input ──────────────────── */
    cli_main -> ir_file    [style=dashed, label="reads", color="#78909c"];
    cli_main -> dot_file   [style=dashed, label="reads", color="#78909c"];
    cli_main -> trace_file [style=dashed, label="reads", color="#78909c"];

    /* ── Edges: Input → Ingest ───────────────── */
    ir_file    -> llvm_events [label="parse", color="#43a047"];
    dot_file   -> dot_layout  [label="parse", color="#43a047"];
    trace_file -> trace_io    [label="parse", color="#43a047"];

    /* ── Edges: Ingest → Transform ───────────── */
    llvm_events -> models   [label="ProgramEventStream", color="#ef6c00"];
    cfg_edge_io -> models   [label="CFGEdge list", color="#ef6c00"];
    trace_io    -> trace    [label="TraceOverlay", color="#ef6c00"];
    analysis_io -> models   [label="BlockMetadata", color="#ef6c00"];
    models      -> commands [label="stream", color="#ef6c00"];
    models      -> scene    [label="stream + edges", color="#ef6c00"];
    trace       -> scene    [label="overlay", color="#ef6c00"];

    /* ── Edges: Transform → Present ──────────── */
    scene    -> graphviz_export [label="SceneGraph", color="#1565c0"];
    scene    -> json_export     [label="SceneGraph", color="#1565c0"];
    scene    -> cfg_anim        [label="SceneGraph\n+ DotLayout", color="#1565c0"];
    commands -> scene_builder   [label="AnimationCommand[]", color="#1565c0"];
    scene_builder -> render_model [color="#1565c0"];
    render_model  -> rich_stack   [label="RenderStep[]", color="#1565c0"];
    rich_stack    -> manim_stack  [color="#1565c0"];
    rich_stack    -> ssa_fmt      [style=dashed, color="#90a4ae"];
    dot_layout    -> cfg_anim     [label="DotLayout", style=dashed, color="#90a4ae"];

    /* ── Edges: Present → Output ─────────────── */
    rich_stack      -> out_mp4  [label="render", color="#c62828"];
    cfg_anim        -> out_mp4  [label="render", color="#c62828"];
    graphviz_export -> out_png  [label="export", color="#c62828"];
    json_export     -> out_json [label="export", color="#c62828"];
}
